# Caddyfile — caddy-proxmox-provider example
#
# The "proxmox" global block registers a background app that polls
# Proxmox VE and injects reverse-proxy routes automatically.
#
# Build with:
#   xcaddy build --with github.com/ndowens/caddy-proxmox-provider

{
    proxmox {
        api_endpoint  https://pve.homelab.local:8006
        api_token_id  root@pam!caddy
        api_token     {env.PROXMOX_API_TOKEN}
        poll_interval 30s
        validate_ssl  false
        label_prefix  caddy.
    }
}

# Optional: catch-all / health check for anything not matched by
# the dynamically generated routes.
:80 {
    respond "caddy-proxmox-provider is running" 200
}
